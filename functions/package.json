{
  "name": "nexxus-bhsa-functions",
  "description": "Firebase Cloud Functions for Nexxus BHSA — email notifications via Brevo",
  "scripts": {
    "lint": "eslint --ext .js,.ts .",
    "build": "echo 'No build step needed for JS functions'",
    "deploy": "firebase deploy --only functions",
    "serve": "firebase emulators:start --only functions",
    "shell": "firebase functions:shell",
    "start": "npm run shell",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "18"
  },
  "main": "src/index.js",
  "dependencies": {
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^5.0.0",
    "nodemailer": "^6.9.13"
  },
  "devDependencies": {
    "eslint": "^8.15.0",
    "eslint-config-google": "^0.14.0"
  },
  "private": true
}
